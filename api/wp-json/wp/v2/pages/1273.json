{"id":1273,"date":"2026-06-11T15:26:00","date_gmt":"2026-06-11T14:26:00","guid":{"rendered":"https:\/\/project-skyscraper.com\/?page_id=1273"},"modified":"2026-06-11T15:23:36","modified_gmt":"2026-06-11T14:23:36","slug":"report-par-temporal-merge","status":"publish","type":"page","link":"https:\/\/project-skyscraper.com\/report-par-temporal-merge\/","title":{"rendered":"Report: PARIS"},"content":{"rendered":"\n<div style=\"position: relative; width: 100%; max-width: 900px; margin: 40px auto; overflow: hidden; border-radius: 6px;\">\n  <canvas id=\"layersCanvas\" style=\"width: 100%; height: auto; display: block;\"><\/canvas>\n<\/div>\n\n<script>\n\/\/ ==================== GLITCH BLUR ====================\nconst canvas = document.getElementById('layersCanvas');\nconst ctx = canvas.getContext('2d', { alpha: true });\n\nlet img = new Image();\nimg.src = \"https:\/\/iili.io\/CC2x7xs.jpg\";\n\nlet time = 0;\n\nimg.onload = () => {\n  canvas.width = img.width;\n  canvas.height = img.height;\n\n  animate();\n};\n\nfunction animate() {\n  time += 0.018;\n\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n  \/\/ Calque 1 - Principal\n  ctx.globalAlpha = 0.75;\n  ctx.drawImage(img, Math.sin(time * 0.3) * 4, Math.cos(time * 0.4) * 3);\n\n  \/\/ Calque 2 - Flou moyen\n  ctx.globalAlpha = 0.35;\n  ctx.filter = 'blur(4px)';\n  ctx.drawImage(img, Math.sin(time * 0.7) * 9, Math.cos(time * 0.6) * 6);\n\n  \/\/ Calque 3 - Plus flou et d\u00e9cal\u00e9\n  ctx.globalAlpha = 0.28;\n  ctx.filter = 'blur(7px)';\n  ctx.drawImage(img, Math.sin(time * 0.5) * -11, Math.cos(time * 0.9) * 8);\n\n  \/\/ Calque 4 - Fant\u00f4me l\u00e9ger\n  ctx.globalAlpha = 0.22;\n  ctx.filter = 'blur(3px)';\n  ctx.drawImage(img, Math.sin(time * 1.1) * 13, Math.cos(time * 0.8) * -7);\n\n  ctx.globalAlpha = 1;\n  ctx.filter = 'none';\n\n  \/\/ Teinte froide tr\u00e8s l\u00e9g\u00e8re\n  ctx.fillStyle = \"rgba(20, 25, 45, 0.08)\";\n  ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n  requestAnimationFrame(animate);\n}\n<\/script>\n","protected":false},"excerpt":{"rendered":"","protected":false},"author":279180095,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"closed","ping_status":"closed","template":"","meta":{"advanced_seo_description":"","jetpack_seo_html_title":"","jetpack_seo_noindex":false,"footnotes":""},"class_list":["post-1273","page","type-page","status-publish","hentry"],"jetpack_likes_enabled":true,"jetpack_sharing_enabled":true,"jetpack_shortlink":"https:\/\/wp.me\/PhdnFZ-kx","jetpack-related-posts":[{"id":1223,"url":"https:\/\/project-skyscraper.com\/report-lon-reality-glitch\/","url_meta":{"origin":1273,"position":0},"title":"Report: LONDON","author":"The Architect","date":"1 June 2026","format":false,"excerpt":"","rel":"","context":"Similar post","block_context":{"text":"Similar post","link":""},"img":{"alt_text":"","src":"","width":0,"height":0},"classes":[]},{"id":75,"url":"https:\/\/project-skyscraper.com\/sleep-mode\/","url_meta":{"origin":1273,"position":1},"title":"SLEEP MODE","author":"The Architect","date":"25 April 2026","format":false,"excerpt":"status=nominal \u2588","rel":"","context":"Similar post","block_context":{"text":"Similar post","link":""},"img":{"alt_text":"","src":"","width":0,"height":0},"classes":[]},{"id":288,"url":"https:\/\/project-skyscraper.com\/sec-log-094316-full\/","url_meta":{"origin":1273,"position":2},"title":"Security Log","author":"The Architect","date":"30 May 2026","format":false,"excerpt":"[30\/5\/2026 09:43:16 AM] Event ID 5156 - System Diagnostic Protocol Application Information: Process ID: 16 Application Name: System Diagnostic Information: Archive: Redacted Fragment: ERROR Operator_Auth_Level: MB-A Protocol Information: Memory_reconstruction_engine: Active (Deprecated) Status: Memory bloc addition authorized Warning: Risk of unstable memory anchoring increased Cycle continues \u2588 v=xPG-VM__mwU","rel":"","context":"Similar post","block_context":{"text":"Similar post","link":""},"img":{"